[
  // =============================================
  // MEMBERS DATA FILE
  // =============================================
  // Add one object per member. Push to GitHub and the site updates.
  //
  // FORMAT:
  // {
  //   "name": "Full Name",
  //   "codeforces": "cf_handle",       (leave "" if no account)
  //   "codechef": "cc_handle",         (leave "" if no account)
  //   "leetcode": "lc_handle",         (leave "" if no account)
  //   "isAlumni": false,               (true = graduated member)
  //   "isActive": true                 (true = currently active)
  // }
  //
  // If a username is provided, the site will fetch their LIVE rating
  // from the platform API automatically.
  //
  // EXAMPLE:
  // { "name": "Sukumar", "codeforces": "tourist", "codechef": "", "leetcode": "", "isAlumni": false, "isActive": true }
  // =============================================
]
